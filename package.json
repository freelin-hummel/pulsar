{
  "name": "pulsar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @pulsar/client dev",
    "dev:server": "pnpm --filter @pulsar/server dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "deploy": "pnpm run build && wrangler pages deploy dist",
    "deploy:server": "cd packages/server && npx wrangler deploy",
    "deploy:client": "pnpm run build && wrangler pages deploy dist"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@blocksuite/icons": "2.1.67"
    }
  }
}
