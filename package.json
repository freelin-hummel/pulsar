{
  "name": "pulsar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "dev:server": "pnpm --filter @pulsar/server dev",
    "deploy": "pnpm run build && wrangler pages deploy dist",
    "deploy:server": "cd packages/server && npx wrangler deploy"
  },
  "dependencies": {
    "@pulsar/blocks": "workspace:*",
    "@pulsar/presets": "workspace:*",
    "@pulsar/store": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@swc/core": "^1.15.24",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@blocksuite/icons": "2.1.67"
    }
  }
}
